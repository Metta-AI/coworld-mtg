{
  "name": "coworld-mtg",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --config web/vite.config.ts --host 127.0.0.1",
    "build": "npm run build:legacy && npm run build:phase",
    "build:legacy": "vite build --config web/vite.config.ts",
    "build:phase": "bash scripts/build-phase-client.sh",
    "typecheck": "tsc --noEmit -p web/tsconfig.json",
    "test": "vitest run --config web/vite.config.ts",
    "test:e2e": "npm run build && playwright test -c web/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^26.1.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
