    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens",
        "players"
      ],
      "properties": {
        "tokens": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
