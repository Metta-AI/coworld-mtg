{
  "$schema": "https://raw.githubusercontent.com/Metta-AI/coworld/main/src/coworld/coworld_manifest_schema.json",
  "game": {
    "name": "cogatrice",
    "version": "2.1",
    "description": "Two-player Magic: The Gathering powered by the Phase rules engine, with enforced mana, timing, priority, stack, combat, hidden information, scoring, and replay.",
    "owner": "nishu.builder@gmail.com",
    "config_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens",
        "players"
      ],
      "properties": {
        "tokens": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "players": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "decks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "enum": [
              "red_rush",
              "green_stompy"
            ]
          }
        },
        "games_to_win": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "clock_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 3600
        },
        "decision_cap_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 600
        },
        "player_connect_timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 600
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scores",
        "games",
        "seed",
        "policy_names"
      ],
      "properties": {
        "scores": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number",
            "minimum": 0
          }
        },
        "games": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "game_number",
              "winner_slot",
              "reason",
              "turns",
              "final_life",
              "seed"
            ],
            "properties": {
              "game_number": {
                "type": "integer",
                "minimum": 1
              },
              "winner_slot": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0,
                "maximum": 1
              },
              "reason": {
                "type": "string"
              },
              "turns": {
                "type": "integer",
                "minimum": 0
              },
              "final_life": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "integer"
                }
              },
              "seed": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "policy_names": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runnable": {
      "type": "game",
      "image": "cogatrice-phase:coworld-51691b1cb889",
      "run": [
        "/app/cogatrice-server"
      ],
      "env": {},
      "source_url": "https://github.com/Metta-AI/coworld-mtg/tree/13f8bd664a8caa5b09e5b104b9424fcbfba2f7bc"
    },
    "protocols": {
      "player": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-mtg/blob/13f8bd664a8caa5b09e5b104b9424fcbfba2f7bc/docs/protocol.md"
      },
      "global": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-mtg/blob/13f8bd664a8caa5b09e5b104b9424fcbfba2f7bc/docs/protocol.md"
      }
    },
    "docs": {
      "readme": {
        "type": "uri",
        "value": "https://github.com/Metta-AI/coworld-mtg/blob/13f8bd664a8caa5b09e5b104b9424fcbfba2f7bc/README.md"
      },
      "pages": [
        {
          "id": "rules.md",
          "title": "Cogatrice rules",
          "content": {
            "type": "text",
            "value": "Cogatrice is a two-player Magic duel using bundled 40-card Red Rush and Green Stompy decks. The pinned Phase engine is authoritative for draws, mana, casting, timing, targets, priority, the stack, combat, triggers, state-based actions, and game outcomes. Players may submit only exact actions offered by Phase for their private view. Hidden hands and libraries remain redacted from opponents and spectators. A match ends when one player reaches the configured number of game wins; clocks and explicit concessions are enforced by the host."
          }
        }
      ]
    }
  },
  "player": [
    {
      "type": "player",
      "image": "cogatrice-phase:coworld-51691b1cb889",
      "run": [
        "/app/goldfish"
      ],
      "env": {},
      "source_url": "https://github.com/Metta-AI/coworld-mtg/tree/13f8bd664a8caa5b09e5b104b9424fcbfba2f7bc",
      "id": "cogatrice-goldfish",
      "name": "Cogatrice Phase Goldfish",
      "description": "A deterministic baseline that ranks and submits only the exact legal actions supplied by Phase."
    }
  ],
  "reporter": [],
  "commissioner": [
    {
      "id": "default-commissioner",
      "name": "Default Commissioner",
