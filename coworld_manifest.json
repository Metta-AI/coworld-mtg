              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "decks": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string",
            "enum": [
              "red_rush",
              "green_stompy"
            ]
          }
        },
        "games_to_win": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "swap_decks_each_game": {
          "type": "boolean"
        },
        "clock_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 3600
        },
        "decision_cap_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 600
        },
        "player_connect_timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 600
        }
      }
    },
    "results_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scores",
        "games",
        "seed",
        "policy_names"
      ],
      "properties": {
        "scores": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number",
            "minimum": 0
          }
        },
        "games": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "game_number",
              "winner_slot",
              "reason",
              "turns",
              "final_life",
              "seed"
            ],
            "properties": {
              "game_number": {
                "type": "integer",
                "minimum": 1
              },
              "winner_slot": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0,
                "maximum": 1
              },
              "reason": {
                "type": "string"
              },
              "turns": {
                "type": "integer",
                "minimum": 0
              },
              "final_life": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "integer"
                }
              },
              "seed": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "policy_names": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string"
          }
        }
      }
    },
