        "swap_decks_each_game": {
          "type": "boolean"
        },
        "clock_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 3600
        },
        "decision_cap_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 600
        },
        "player_connect_timeout_s": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 600
        }
      }
    },
    "results_schema": {
