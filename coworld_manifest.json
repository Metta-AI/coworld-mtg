        "scores": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "number",
            "minimum": 0
          }
        },
        "games": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "game_number",
              "winner_slot",
              "reason",
              "turns",
              "final_life",
              "seed"
            ],
            "properties": {
              "game_number": {
                "type": "integer",
                "minimum": 1
              },
              "winner_slot": {
                "type": [
                  "integer",
                  "null"
                ],
                "minimum": 0,
                "maximum": 1
              },
              "reason": {
                "type": "string"
              },
              "turns": {
                "type": "integer",
                "minimum": 0
              },
              "final_life": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": {
                  "type": "integer"
                }
              },
              "seed": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "policy_names": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string"
          }
        }
      }
    },
